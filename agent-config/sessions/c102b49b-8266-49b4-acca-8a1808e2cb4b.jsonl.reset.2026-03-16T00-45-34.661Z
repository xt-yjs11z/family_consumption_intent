= r.json()\n        intent = d.get(\"intent\", {})\n        t = intent.get(\"target\")\n        o = intent.get(\"object\")\n        s = intent.get(\"scene\")\n        q = d.get(\"next_question\")\n        budget = intent.get(\"budget\")\n        \n        if t and o:\n            stats[\"complete\"] += 1\n            if budget:\n                stats[\"budgets\"][budget] = stats[\"budgets\"].get(budget, 0) + 1\n        elif q:\n            stats[\"ask\"] += 1\n        elif s:\n            stats[\"scene\"] += 1\n            \n    except Exception as e:\n        pass\n    \n    if (i + 1) % 50 == 0:\n        print(f\"进度: {i+1}/{len(cases)}\")\n\nprint(f\"\\n===== 测试结果 =====\")\nprint(f\"总计: {stats['total']}\")\nprint(f\"完整识别: {stats['complete']} ({stats['complete']/stats['total']*100:.1f}%)\")\nprint(f\"需要追问: {stats['ask']} ({stats['ask']/stats['total']*100:.1f}%)\")\nprint(f\"场景词: {stats['scene']} ({stats['scene']/stats['total']*100:.1f}%)\")\nprint(f\"\\n预算分布:\")\nfor b, c in sorted(stats[\"budgets\"].items()):\n    print(f\"  {b}: {c}\")\nEOF","timeout":180}}],"api":"anthropic-messages","provider":"minimax-cn","model":"MiniMax-M2.5","usage":{"input":159441,"output":1025,"cacheRead":9179,"cacheWrite":0,"totalTokens":169645,"cost":{"input":0.0478323,"output":0.00123,"cacheRead":0.00027537,"cacheWrite":0,"total":0.04933767}},"stopReason":"toolUse","timestamp":1773389260854}}
