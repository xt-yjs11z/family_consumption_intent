{"type":"message","id":"9492260f","parentId":"ebe88698","timestamp":"2026-03-13T07:15:09.044Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在我有10万条测试用例了。让我进行批量测试，但由于时间和资源限制，我会分批测试。","thinkingSignature":"d1231c15be1d0df02de27706bcd2f89b7153673358cbdbbaf6931e415ea566c4"},{"type":"toolCall","id":"call_function_2zlq0kmdwyiy_1","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport json\nimport requests\nimport time\n\n# 加载测试用例\nwith open('/home/robot/.openclaw/workspace-family_consumption_intent/test_100k_list.json', 'r', encoding='utf-8') as f:\n    cases = json.load(f)\n\nprint(f\"总测试用例: {len(cases)}\")\n\n# 统计\nstats = {\n    \"total\": 0,\n    \"complete\": 0,  # 完整识别（有target+object）\n    \"ask\": 0,       # 需要追问\n    \"error\": 0,     # 错误\n    \"scene_only\": 0 # 只有场景\n}\n\napi_url = \"http://127.0.0.1:3847/api/chat\"\n\n# 测试前1000条（分批测试）\nbatch_size = 1000\ntotal_tests = min(1000, len(cases))\n\nfor i in range(total_tests):\n    msg = cases[i]\n    user_id = f\"test_{i}\"\n    \n    try:\n        resp = requests.post(api_url, json={\"message\": msg, \"userId\": user_id}, timeout=5)\n        data = resp.json()\n        \n        intent = data.get(\"intent\", {})\n        target = intent.get(\"target\")\n        obj = intent.get(\"object\")\n        scene = intent.get(\"scene\")\n        is_complete = data.get(\"is_complete\", False)\n        next_q = data.get(\"next_question\")\n        \n        stats[\"total\"] += 1\n        \n        if target and obj:\n            stats[\"complete\"] += 1\n        elif next_q:\n            stats[\"ask\"] += 1\n        elif scene and not target and not obj:\n            stats[\"scene_only\"] += 1\n        else:\n            stats[\"error\"] += 1\n            \n    except Exception as e:\n        stats[\"error\"] += 1\n        stats[\"total\"] += 1\n    \n    if (i + 1) % 200 == 0:\n        print(f\"已测试: {i+1}/{total_tests}\")\n\nprint(\"\\n===== 测试结果 =====\")\nprint(f\"总测试数: {stats['total']}\")\nprint(f\"完整识别: {stats['complete']} ({stats['complete']/stats['total']*100:.1f}%)\")\nprint(f\"需要追问: {stats['ask']} ({stats['ask']/stats['total']*100:.1f}%)\")\nprint(f\"场景词: {stats['scene_only']} ({stats['scene_only']/stats['total']*100:.1f}%)\")\nprint(f\"错误: {stats['error']} ({stats['error']/stats['total']*100:.1f}%)\")\n\n# 保存结果\nwith open('/home/robot/.openclaw/workspace-family_consumption_intent/test_result.json', 'w', encoding='utf-8') as f:\n    json.dump(stats, f, ensure_ascii=False, indent=2)\n\nprint(\"\\n结果已保存\")\nEOF","timeout":180}}],"api":"anthropic-messages","provider":"minimax-cn","model":"MiniMax-M2.5","usage":{"input":133033,"output":691,"cacheRead":9179,"cacheWrite":0,"totalTokens":142903,"cost":{"input":0.0399099,"output":0.0008292,"cacheRead":0.00027537,"cacheWrite":0,"total":0.04101447}},"stopReason":"toolUse","timestamp":1773386094486}}
