          { name: '华为nova 12', reason: '拍照效果好' }\n          ],\n          next_question: null\n        }\n      ];\n      renderChat();\n    }\n  </script>"}}],"api":"anthropic-messages","provider":"minimax-cn","model":"MiniMax-M2.5","usage":{"input":21109,"output":529,"cacheRead":9179,"cacheWrite":0,"totalTokens":30817,"cost":{"input":0.0063327,"output":0.0006347999999999999,"cacheRead":0.00027537,"cacheWrite":0,"total":0.007242869999999999}},"stopReason":"toolUse","timestamp":1773378475588}}
