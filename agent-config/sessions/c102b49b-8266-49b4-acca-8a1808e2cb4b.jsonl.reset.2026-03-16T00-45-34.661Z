\"婴儿车\", \"腰凳\"], \"price\": \"300-800元\", \"tips\": \"品质不错\"}],\n+255         \"generous\": [{\"brand\": \"Bugaboo\", \"products\": [\"婴儿车\"], \"price\": \"5000-10000元\", \"tips\": \"高端婴儿车\"}],\n+256         \"luxury\": [{\"brand\": \"Stokke\", \"products\": [\"婴儿床\", \"餐椅\"], \"price\": \"10000元以上\", \"tips\": \"奢华品质\"}\n+257     },\n+258     \"beauty\": {\n+259         \"rational\": [{\"brand\": \"完美日记\", \"products\": [\"口红\", \"眼影\"], \"price\": \"50-150元\", \"tips\": \"性价比高\"}],\n+260         \"frugal\": [{\"brand\": \"国产品牌\", \"products\": [\"护肤品\"], \"price\": \"50-100元\", \"tips\": \"实惠够用\"}],\n+261         \"moderate\": [{\"brand\": \"兰蔻\", \"products\": [\"精华\", \"面霜\"], \"price\": \"300-800元\", \"tips\": \"口碑不错\"}],\n+262         \"generous\": [{\"brand\": \"雅诗兰黛\", \"products\": [\"小棕瓶\", \"眼霜\"], \"price\": \"500-1000元\", \"tips\": \"高端护肤\"}],\n+263         \"luxury\": [{\"brand\": \"La Mer\", \"products\": [\"面霜\"], \"price\": \"3000元以上\", \"tips\": \"顶级奢华\"}\n+264     },\n 244     \"food\": {\n-245         \"rational\": [{\"brand\": \"应季水果\", \"products\": [\"苹果\", \"香蕉\"], \"price\": \"10-30元\"}],\n-246         \"frugal\": [{\"brand\": \"散装食品\", \"products\": [\"大米\", \"面粉\"], \"price\": \"20-50元\"}],\n-247         \"moderate\": [{\"brand\": \"盒马\", \"products\": [\"海鲜\", \"水果\"], \"price\": \"50-150元\"}],\n-248         \"generous\": [{\"brand\": \"山姆会员店\", \"products\": [\"进口食品\", \"有机食品\"], \"price\": \"100-500元\"}],\n-249         \"luxury\": [{\"brand\": \"和牛\", \"products\": [\"进口牛肉\"], \"price\": \"500-2000元\"}]\n+266         \"rational\": [{\"brand\": \"应季水果\", \"products\": [\"苹果\", \"香蕉\"], \"price\": \"10-30元\", \"tips\": \"新鲜实惠\"}],\n+267         \"frugal\": [{\"brand\": \"散装食品\", \"products\": [\"大米\", \"面粉\"], \"price\": \"20-50元\", \"tips\": \"经济实惠\"}],\n+268         \"moderate\": [{\"brand\": \"盒马\", \"products\": [\"海鲜\", \"水果\"], \"price\": \"50-150元\", \"tips\": \"品质保证\"}],\n+269         \"generous\": [{\"brand\": \"山姆会员店\", \"produ