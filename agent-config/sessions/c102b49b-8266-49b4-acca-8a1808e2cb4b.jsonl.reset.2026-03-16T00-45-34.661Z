{"type":"message","id":"e3477a42","parentId":"f7194861","timestamp":"2026-03-13T07:34:58.645Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me run the 1000 test cases.","thinkingSignature":"05fd55bcd8497a995f3715103281a02eb907785b41a01a0a95fba8853821cb38"},{"type":"toolCall","id":"call_function_r95bjqs8tqvw_1","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport requests\nimport random\nimport time\n\n# 测试用例\nproducts = [\"空调\", \"冰箱\", \"洗衣机\", \"电视\", \"手机\", \"电脑\", \"平板\", \"耳机\", \"相机\", \"游戏机\",\n    \"衣服\", \"裤子\", \"裙子\", \"鞋子\", \"外套\", \"羽绒服\", \"玩具\", \"零食\", \"水果\", \"牛奶\",\n    \"茶叶\", \"蛋糕\", \"化妆品\", \"护肤品\", \"香水\", \"口红\", \"面膜\", \"保健品\", \"扫地机器人\",\n    \"婴儿车\", \"尿不湿\", \"遛娃神器\", \"婴儿床\", \"儿童椅\", \"床\", \"沙发\", \"衣柜\", \"书柜\",\n    \"自行车\", \"电动车\", \"汽车\", \"健身器材\", \"跑步机\", \"哑铃\", \"瑜伽垫\", \"猫粮\", \"狗粮\"]\n\ntargets = [\"给孩子\", \"给父母\", \"给家里\", \"给老婆\", \"给老公\", \"给宝宝\", \"给儿子\", \"给女儿\"]\nscenes = [\"过年\", \"中秋节\", \"国庆节\", \"生日\", \"情人节\", \"母亲节\", \"父亲节\", \"六一儿童节\", \"开学了\", \"坏了\", \"换季\", \"双11\"]\nvague = [\"礼物\", \"东西\", \"物品\", \"买点东西\", \"看看\", \"推荐\"]\n\ncases = []\n\n# 完整对话 40%\nfor _ in range(400):\n    t = random.choice(targets)\n    p = random.choice(products)\n    cases.append(f\"{t}买{p}\")\n\n# 商品+场景 20%\nfor _ in range(200):\n    s = random.choice(scenes)\n    p = random.choice(products)\n    cases.append(f\"{s}买{p}\")\n\n# 单独商品 20%\nfor _ in range(200):\n    p = random.choice(products)\n    cases.append(f\"买{p}\")\n\n# 场景词 10%\nfor _ in range(100):\n    cases.append(random.choice(scenes))\n\n# 模糊词 10%\nfor _ in range(100):\n    cases.append(random.choice(vague))\n\nrandom.shuffle(cases)\n\n# 统计\nstats = {\"total\": 0, \"complete\": 0, \"ask\": 0, \"scene\": 0, \"error\": 0}\n\nprint(f\"总测试用例: {len(cases)}\")\n\nfor i, msg in enumerate(cases):\n    try:\n        resp = requests.post(\"http://127.0.0.1:3847/api/chat\", json={\"message\": msg, \"userId\": f\"t{i}\"}, timeout=5)\n        data = resp.json()\n        \n        intent = data.get(\"intent\", {})\n        target = intent.get(\"target\")\n        obj = intent.get(\"object\")\n        scene = intent.get(\"scene\")\n        next_q = data.get(\"next_question\")\n        \n        stats[\"total\"] += 1\n        \n        if target and obj:\n            stats[\"complete\"] += 1\n        elif next_q:\n            stats[\"ask\"] += 1\n        elif scene and not target and not obj:\n            stats[\"scene\"] += 1\n        else:\n            stats[\"error\"] += 1\n            \n    except Exception as e:\n        stats[\"error\"] += 1\n        stats[\"total\"] += 1\n    \n    if (i + 1) % 200 == 0:\n        print(f\"进度: {i+1}/{len(cases)}\")\n\nprint(\"\\n===== 测试结果 =====\")\nprint(f\"总测试数: {stats['total']}\")\nprint(f\"完整识别: {stats['complete']} ({stats['complete']/stats['total']*100:.1f}%)\")\nprint(f\"需要追问: {stats['ask']} ({stats['ask']/stats['total']*100:.1f}%)\")\nprint(f\"场景词: {stats['scene']} ({stats['scene']/stats['total']*100:.1f}%)\")\nprint(f\"错误: {stats['error']} ({stats['error']/stats['total']*100:.1f}%)\")\n\n# 成功率计算\nsuccess_rate = (stats['complete'] + stats['scene'] + stats['ask']) / stats['total'] * 100\nprint(f\"\\n有效率: {success_rate:.1f}%\")\nEOF","timeout":180}}],"api":"anthropic-messages","provider":"minimax-cn","model":"MiniMax-M2.5","usage":{"input":146731,"output":961,"cacheRead":9179,"cacheWrite":0,"totalTokens":156871,"cost":{"input":0.0440193,"output":0.0011531999999999998,"cacheRead":0.00027537,"cacheWrite":0,"total":0.045447869999999994}},"stopReason":"toolUse","timestamp":1773387279785}}
