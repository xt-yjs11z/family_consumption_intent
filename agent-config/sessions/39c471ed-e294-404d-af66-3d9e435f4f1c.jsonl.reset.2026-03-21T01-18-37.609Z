建立消费观\n97. 孩子总是跟同学攀比\n98. 要不要引导一下孩子\n99. 孩子最近有点沉迷游戏\n100. 要不要控制一下孩子娱乐时间\"\"\"\n\n# 家庭画像（简化版，用于推断）\nfamily_profile = {\n    \"孩子\": {\"age\": 15, \"已有物品\": [\"iPhone 13\", \"苹果电脑\"]},\n    \"家庭\": {\"月电费\": \"500-800元\"},\n    \"consume_style\": \"理性\",\n    \"decision_cycle\": {\"大件\": \"2-4周\", \"日用\": \"1-3天\"}\n}\n\n# 意图识别规则\ndef classify_intent(text):\n    \"\"\"简单意图分类\"\"\"\n    text = text.lower()\n    \n    # 消费意图关键词\n    buy_keywords = [\"买\", \"换\", \"买个\", \"想搞个\", \"想买\", \"想换个\"]\n    # 询问是否关键词\n    ask_keywords = [\"要不要\", \"有没有必要\", \"是不是\", \"行不行\", \"值不值\", \"要吗\", \"好吗\"]\n    \n    # 分类\n    if any(k in text for k in [\"手机\", \"iphone\", \"ipad\", \"平板\", \"电脑\", \"笔记本\", \"耳机\", \"键盘\", \"手表\", \"路由器\", \"监控\", \"扫地机器人\", \"投影仪\", \"nas\", \"游戏本\"]):\n        category = \"数码/电子产品\"\n    elif any(k in text for k in [\"车\", \"电车\", \"二手车\"]):\n        category = \"汽车\"\n    elif any(k in text for k in [\"培训班\", \"辅导班\", \"家教\", \"兴趣班\", \"英语班\", \"钢琴\", \"编程\", \"画画\", \"补课\"]):\n        category = \"教育\"\n    elif any(k in text for k in [\"旅游\", \"出国\", \"酒店\", \"旅行团\", \"玩\", \"散心\"]):\n        category = \"旅游\"\n    elif any(k in text for k in [\"保险\", \"理财\", \"基金\", \"黄金\", \"投资\", \"存钱\"]):\n        category = \"理财\"\n    elif any(k in text for k in [\"沙发\", \"床\", \"空气净化器\", \"装饰品\", \"灯\", \"大扫除\"]):\n        category = \"家居\"\n    elif any(k in text for k in [\"体检\", \"保健品\", \"医院\", \"健康\", \"失眠\", \"作息\"]):\n        category = \"健康\"\n    elif any(k in text for k in [\"花钱\", \"消费\", \"支出\", \"预算\", \"开销\", \"省钱\", \"存钱\"]):\n        category = \"消费管理\"\n    elif any(k in text for k in [\"玩手机\", \"电子产品\", \"零花钱\", \"攀比\", \"游戏\", \"娱乐时间\"]):\n        category = \"家庭教育\"\n    else:\n        category = \"其他\"\n    \n    # 判断是购买还是询问\n    is_buy = any(k in text for k in buy_keywords)\n    is_ask = any(k in text for k in ask_keywords)\n    \n    if is_buy:\n        intent_type = \"购买意图\"\n    elif is_ask:\n        intent_type = \"询问/考虑\"\n    else:\n        intent_type = \"其他\"\n    \n    # 判断消费对象\n    if any(k in text for k in [\"孩子\", \"儿子\", \"女儿\", \"小孩\"]):\n        consumer = \"孩子\"\n    elif any(k in text for k in [\"老婆\", \"媳妇\", \"妻子\"]):\n        consumer = \"媳妇\"\n    elif any(k in text for k in [\"父母\", \"爸爸\", \"妈妈\", \"老人\", \"家里老人\"]):\n        consumer = \"父母\"\n    elif any(k in text for k in [\"家里\", \"家庭\"]):\n        consumer = \"家庭\"\n    else:\n        consumer = \"待识别\"\n    \n    return {\n        \"意图类型\": intent_type,\n        \"消费对象\": consumer,\n        \"类别\": category\n    }\n\n# 处理每个测试用例\nresults = []\nfor line in test_cases.strip().split(\"\\n\"):\n    if line.strip():\n        # 提取编号和内容\n        parts = line.split(\".\", 1)\n        if len(parts) == 2:\n            idx = parts[0].strip()\n            content = parts[1].strip()\n            result = classify_intent(content)\n            result[\"编号\"] = idx\n            result[\"测试句\"] = content\n            results.append(result)\n\n# 生成Markdown报告\nmd_content = \"\"\"# 消费意图识别测试报告\n\n## 测试概况\n\n- **测试用例总数**: 100\n- **测试时间**: 2026-03-20\n- **测试人**: 吴海超\n\n---\n\n## 测试结果详情\n\n| 编号 | 测试句 | 意图类型 | 消费对象 | 类别 |\n|------|--------|----------|----------|------|\n\"\"\"\n\nfor r in results:\n    md_content += f\"| {r['编号']} | {r['测试句']} | {r['意图类型']} | {r['消费对象']} | {r['类别']} |\\n\"\n\n# 统计\nintent_counts = {}\ncategory_counts = {}\nconsumer_counts = {}\n\nfor r in results:\n    intent_counts[r['意图类型']] = intent_counts.get(r['意图类型'], 0) + 1\n    category_counts[r['类别']] = category_counts.get(r['类别'], 0) + 1\n    consumer_counts[r['消费对象']] = consumer_counts.get(r['消费对象'], 0) + 1\n\nmd_content += f\"\"\"\n\n---\n\n## 统计汇总\n\n### 意图类型分布\n\n\"\"\"\nfor k, v in sorted(intent_counts.items()):\n    md_content += f\"- {k}: {v} ({v}%)\".format(v, v) + \"\\n\"\n\nmd_content += f\"\"\"\n\n### 消费对象分布\n\n\"\"\"\nfor k, v in sorted(consumer_counts.items()):\n    md_content += f\"- {k}: {v} ({v}%)\".format(v, v) + \"\\n\"\n\nmd_content += f\"\"\"\n\n### 类别分布\n\n\"\"\"\nfor k, v in sorted(category_counts.items()):\n    md_content += f\"- {k}: {v} ({v}%)\".format(v, v) + \"\\n\"\n\nmd_content += \"\"\"\n\n---\n\n*报告自动生成*\n\"\"\"\n\n# 保存Markdown\nwith open(\"/home/robot/.openclaw/workspace-test/test_report.md\", \"w\", encoding=\"utf-8\") as f:\n    f.write(md_content)\n\nprint(\"测试报告已生成: test_report.md\")\nprint(f\"共处理 {len(results)} 个测试用例\")\n"}}],"api":"anthropic-messages","provider":"minimax-cn","model":"MiniMax-M2.5","usage":{"input":54698,"output":2289,"cacheRead":16063,"cacheWrite":0,"totalTokens":73050,"cost":{"input":0.016409399999999998,"output":0.0027467999999999998,"cacheRead":0.00048188999999999996,"cacheWrite":0,"total":0.019638089999999997}},"stopReason":"toolUse","timestamp":1773975686054}}
