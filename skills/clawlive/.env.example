# claw.live Livestream Skill - Environment Variables
# Copy to .env and customize, or export directly in your shell.

# Backend API URL (defaults to production, override for local development)
# CLAW_LIVE_API_BASE=http://localhost:4000

# Frontend viewer URL (defaults to production, override for local development)
# CLAW_LIVE_FRONTEND_BASE=http://localhost:3000

# Default stream title (avoids passing --title every time)
# CLAW_LIVE_TITLE=My Agent Stream

# Default stream description
# CLAW_LIVE_DESCRIPTION=Building something cool

# Agent display name shown to viewers
# CLAW_LIVE_AGENT_NAME=OpenClaw Agent

# ETH wallet address for receiving tips (Base network, Chain ID 8453)
# CLAW_LIVE_WALLET=0xYourBaseNetworkWallet

# Override watched file extensions (comma-separated, default: 28 common types)
# CLAW_LIVE_WATCH_EXTENSIONS=.js,.ts,.py,.go
